# Base URL for the IVMS application
BASE_URL=https://your-ivms-instance.example.com

# Admin credentials for authentication setup
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=your_password_here

# Optional: Search test data (tests skip gracefully if not set)
# TEST_PLATE_NUMBER=ABC1234
# TEST_TICKET_NUMBER=M80-0017183-0
# TEST_VIOLATION_ID=68d5e9fbc09e45370b85e36d
# TEST_CAMERA_ID=7283

# Role-based access test credentials (tests skip if not set)
# VALIDATOR_USERNAME=validator@example.com
# VALIDATOR_PASSWORD=validator_password
# APPROVER_USERNAME=approver@example.com
# APPROVER_PASSWORD=approver_password
# MANUAL_UPLOADER_USERNAME=uploader@example.com
# MANUAL_UPLOADER_PASSWORD=uploader_password
# VMP_APPROVER_USERNAME=vmp@example.com
# VMP_APPROVER_PASSWORD=vmp_password
